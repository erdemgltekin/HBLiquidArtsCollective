@page
@model ProjelerimizModel
@{
    ViewData["Title"] = "Projelerimiz";
}

@section Styles {
    <link rel="stylesheet" href="~/css/projelerimiz.css" asp-append-version="true" />
}

<div class="page-container">
    <div class="content-wrapper">
        <header class="page-header">
            <h1 class="page-title">Projelerimiz</h1>
            <p class="page-desc">Gerçekleştirdiğimiz premium etkinlikler ve başarı hikayeleri</p>
        </header>

        <!-- 1. İstatistik Bölümü -->
        <section class="stats-grid">
            <div class="stat-card">
                <span class="stat-number">250+</span>
                <span class="stat-label">Tamamlanan Proje</span>
            </div>
            <div class="stat-card">
                <span class="stat-number">180+</span>
                <span class="stat-label">Mutlu Müşteri</span>
            </div>
            <div class="stat-card">
                <span class="stat-number">50K+</span>
                <span class="stat-label">Servis Edilen Kokteyl</span>
            </div>
            <div class="stat-card">
                <span class="stat-number">2K+</span>
                <span class="stat-label">Workshop Katılımcısı</span>
            </div>
        </section>

        <!-- 2. Proje Kartları Bölümü -->
        <section class="projects-grid">
            <div class="project-card">
                <div class="card-image">
                    <img src="~/images/projects/project1.jpg" alt="İstanbul Luxury Hotel Gala" />
                    <span class="category-badge">Kurumsal Etkinlik</span>
                </div>
                <div class="card-content">
                    <h3 class="project-title">İstanbul Luxury Hotel Gala</h3>
                    <p class="project-description">Premium otel açılış galası için özel kokteyl deneyimi ve bar servisi</p>
                    <div class="project-meta">
                        <div class="meta-item">
                            <i class="bi bi-calendar-event"></i>
                            <span>15 Ocak 2026</span>
                        </div>
                        <div class="meta-item">
                            <i class="bi bi-geo-alt"></i>
                            <span>İstanbul</span>
                        </div>
                        <div class="meta-item">
                            <i class="bi bi-people"></i>
                            <span>250 Kişi</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="project-card">
                <div class="card-image">
                    <img src="~/images/projects/project2.jpg" alt="Kurumsal Miksoloji Workshop" />
                    <span class="category-badge">Workshop</span>
                </div>
                <div class="card-content">
                    <h3 class="project-title">Kurumsal Miksoloji Workshop</h3>
                    <p class="project-description">Finans şirketi için özel ekip çalışması ve miksoloji eğitimi</p>
                    <div class="project-meta">
                        <div class="meta-item">
                            <i class="bi bi-calendar-event"></i>
                            <span>3 Şubat 2026</span>
                        </div>
                        <div class="meta-item">
                            <i class="bi bi-geo-alt"></i>
                            <span>Ankara</span>
                        </div>
                        <div class="meta-item">
                            <i class="bi bi-people"></i>
                            <span>40 Kişi</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="project-card">
                <div class="card-image">
                    <img src="~/images/projects/project3.jpg" alt="Premium Bar Catering" />
                    <span class="category-badge">Catering</span>
                </div>
                <div class="card-content">
                    <h3 class="project-title">Premium Bar Catering</h3>
                    <p class="project-description">Sahil kenarında düğün için lüks kokteyl bar kurulumu</p>
                    <div class="project-meta">
                        <div class="meta-item">
                            <i class="bi bi-calendar-event"></i>
                            <span>20 Aralık 2025</span>
                        </div>
                        <div class="meta-item">
                            <i class="bi bi-geo-alt"></i>
                            <span>Bodrum</span>
                        </div>
                        <div class="meta-item">
                            <i class="bi bi-people"></i>
                            <span>180 Kişi</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 3. Alt Bölüm (CTA) -->
        <section class="cta-section">
            <div class="cta-card">
                <h2 class="cta-title">Sizin de bir projeniz mi var?</h2>
                <p class="cta-desc">Hayalinizdeki etkinliği birlikte gerçekleştirelim. Premium kokteyl deneyimleri için hemen iletişime geçin.</p>
                <a href="/teklif-al" class="btn-premium">Teklif Al</a>
            </div>
        </section>
    </div>
</div>
