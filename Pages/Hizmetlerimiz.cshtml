@page
@model HizmetlerimizModel
@{
    ViewData["Title"] = "Hizmetlerimiz";
    ViewData["Description"] = "İçecek deneyiminizi yükseltmek için kapsamlı çözümler, danışmanlık, workshop ve catering hizmetleri.";
}

@section Styles {
    <link rel="stylesheet" href="~/css/hizmetlerimiz.css" asp-append-version="true" />
}

@* Hero Section *@
<section class="page-hero">
    <div class="container text-center">
        <h1 class="hero-title">Hizmetlerimiz</h1>
        <p class="hero-subtitle">İçecek deneyiminizi yükseltmek için kapsamlı çözümler</p>
    </div>
</section>

@* Main Services *@
<section class="main-services-section">
    <div class="container">
        <div class="row g-4">
            @* Service 1: Danışmanlık *@
            <div class="col-lg-4">
                <div class="service-card large-card" data-service-id="consultancy">
                    <div class="card-image-wrapper">
                        <img src="/img/service-consultancy.jpg" alt="Danışmanlık">
                    </div>
                    <div class="card-content">
                        <div class="service-icon"><i class="bi bi-briefcase"></i></div>
                        <h3>Danışmanlık</h3>
                        <p>Oteller, restoranlar ve premium mekanlar için stratejik içecek programı geliştirme, menü küratörlüğü ve bar tasarım danışmanlığı.</p>
                        <span class="card-link">Detayları Görüntüle</span>
                    </div>
                </div>
            </div>

            @* Service 2: Workshop *@
            <div class="col-lg-4">
                <div class="service-card large-card" data-service-id="workshop">
                    <div class="card-image-wrapper">
                        <img src="/img/service-workshop.jpg" alt="Workshop">
                    </div>
                    <div class="card-content">
                        <div class="service-icon"><i class="bi bi-mortarboard"></i></div>
                        <h3>Workshop</h3>
                        <p>Craft sanatında ustalaşmak isteyen meraklılar ve profesyoneller için tasarlanmış sürükleyici miksoloji sınıfları ve içki eğitim programları.</p>
                        <span class="card-link">Detayları Görüntüle</span>
                    </div>
                </div>
            </div>

            @* Service 3: Catering *@
            <div class="col-lg-4">
                <div class="service-card large-card" data-service-id="catering">
                    <div class="card-image-wrapper">
                        <img src="/img/service-catering.jpg" alt="Catering">
                    </div>
                    <div class="card-content">
                        <div class="service-icon"><i class="bi bi-stars"></i></div>
                        <h3>Catering</h3>
                        <p>Premium sunum ve hizmetle özel etkinlikler, kurumsal fonksiyonlar ve kutlamalar için özel kokteyl deneyimleri.</p>
                        <span class="card-link">Detayları Görüntüle</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* Additional Services (Ek Hizmetlerimiz) *@
<section class="extra-services-section">
    <div class="container">
        <h2 class="section-title text-center">Ek Hizmetlerimiz</h2>
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="service-card small-card" data-service-id="bar-concept">
                    <div class="card-content text-center">
                        <div class="service-icon-small"><i class="bi bi-award"></i></div>
                        <h3>Bar Konseptleri</h3>
                        <p>Markanıza özel benzersiz bar konseptleri ve tasarımları oluşturuyoruz.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="service-card small-card" data-service-id="staff-training">
                    <div class="card-content text-center">
                        <div class="service-icon-small"><i class="bi bi-people"></i></div>
                        <h3>Personel Eğitimi</h3>
                        <p>Ekibinizi en yüksek hizmet standartlarına ve miksoloji tekniklerine hazırlıyoruz.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="service-card small-card" data-service-id="menu-opt">
                    <div class="card-content text-center">
                        <div class="service-icon-small"><i class="bi bi-graph-up-arrow"></i></div>
                        <h3>Menü Optimizasyonu</h3>
                        <p>Karlılığı artıran ve müşteri memnuniyetini maksimize eden stratejik menü geliştirme.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* Why Us Section *@
<section class="why-us-section">
    <div class="container container-glass">
        <h2 class="section-title text-center">Neden HB Liquid Arts?</h2>
        <div class="row g-5 mt-4">
            <div class="col-md-6">
                <div class="why-item">
                    <h3>Deneyim ve Uzmanlık</h3>
                    <p>15 yılı aşkın endüstri deneyimi ile dünya standartlarında içecek çözümleri sunuyoruz. Uluslararası sertifikalarımız ve ödüllerimiz kalitemizin garantisidir.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="why-item">
                    <h3>Kişiselleştirilmiş Çözümler</h3>
                    <p>Her işletmenin benzersiz ihtiyaçları olduğunu biliyoruz. Size özel çözümler geliştirerek markanızı rakiplerinizden farklılaştırıyoruz.</p>
                </div>
            </div>
        </div>
    </div>
</section>

@* Contact Form *@
@await Html.PartialAsync("_ContactForm")

@* Service Detail Overlay *@
<div id="serviceDetailOverlay" class="service-overlay">
    <div class="overlay-glass"></div>
    <div class="overlay-content-wrapper">
        <button id="closeOverlay" class="btn-close-overlay"><i class="bi bi-x-lg"></i></button>
        <div id="overlayBody" class="overlay-body">
            @* JS will fill this *@
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/hizmetlerimiz/hizmetlerimiz.js" asp-append-version="true"></script>
}
