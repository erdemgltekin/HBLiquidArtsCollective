<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@(ViewData["Title"] ?? "HB Liquid Arts Collective - Butik Miksoloji & Danışmanlık")</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Sıradan deneyimleri olağanüstü sıvı sanatına dönüştürüyoruz.")" />
    <meta name="keywords" content="@(ViewData["Keywords"] ?? "hb,HB,Hakan Balta,kokteyl,danışmanlık,bar,bar catering,organizasyon,workshop,bar eğitim,liquid arts,collective,mixology")" />
    <meta name="author" content="HB Liquid Arts Collective" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="animated-bg">

    <header class="main-header" id="siteHeader">
        <div class="header-container">
            <nav class="custom-navbar">
                <a class="brand-link" href="/">
                    <div class="brand-logo">HB</div>
                    <div class="brand-text">
                        <span class="brand-light">Liquid Arts</span>
                        <span class="brand-collective">Collective</span>
                    </div>
                </a>

                <button class="menu-toggler" id="mobileMenuBtn">
                    <span class="toggler-icon"></span>
                </button>

                <div class="nav-menu" id="mainNav">
                    <ul class="nav-list">
                        <li class="nav-item"><a class="nav-link" href="/hizmetlerimiz">Hizmetlerimiz</a></li>
                        <li class="nav-item"><a class="nav-link" href="/danismanliklar">Danışmanlıklar</a></li>
                        <li class="nav-item"><a class="nav-link" href="/projelerimiz">Projelerimiz</a></li>
                        <li class="nav-item"><a class="nav-link" href="/galeri">Galeri</a></li>
                        <li class="nav-item"><a class="nav-link" href="/hakkimizda">Hakkımızda</a></li>
                        <li class="nav-item cta-item">
                            <a class="btn-cta" href="/#contact-form-section">Teklif Al</a>
                        </li>
                    </ul>
                </div>
            </nav>
        </div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="main-footer">
        <div class="footer-container">
            <div class="footer-content">
                @* Sol Sütun: Logo ve Açıklama *@
                <div class="footer-info-section">
                    <div class="footer-logo-area">
                        <div class="brand-logo">HB</div>
                        <div class="brand-text">
                            <span class="brand-light">Liquid Arts</span>
                            <span class="brand-gold">Kolektifi</span>
                        </div>
                    </div>
                    <p class="footer-desc">2020'den beri craft kokteyl sanatını ve içki eğitimini yükseltiyoruz.</p>
                </div>

                @* Orta Sütun: Hızlı Bağlantılar *@
                <div class="footer-links-section">
                    <h3 class="footer-title">Hızlı Bağlantılar</h3>
                    <ul class="footer-links-list">
                        <li><a href="/">Kurucu</a></li>
                        <li><a href="/hizmetlerimiz">Hizmetlerimiz</a></li>
                        <li><a href="/danismanliklar">Danışmanlıklar</a></li>
                        <li><a href="/projelerimiz">Projelerimiz</a></li>
                        <li><a href="/galeri">Galeri</a></li>
                    </ul>
                </div>

                @* Sağ Sütun: Sosyal Medya *@
                <div class="footer-social-section">
                    <h3 class="footer-title">Bizi Takip Edin</h3>
                    <div class="social-links-container">
                        <a href="#" class="social-icon-link"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-icon-link"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="social-icon-link"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="social-icon-link"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
            </div>

            <div class="footer-bottom-area">
                <p>&copy; @DateTime.Now.Year HB Liquid Arts Kolektifi. Tüm hakları saklıdır.</p>
            </div>
        </div>
    </footer>

    <a href="https://wa.me/905427159058" target="_blank" class="whatsapp-float" aria-label="WhatsApp İletişim">
        <span class="wa-icon"></span>
        <span class="wa-pulse"></span>
    </a>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/main.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>