@page
@model GaleriModel
@{
    ViewData["Title"] = "Galeri";
}

@section Styles {
    <link rel="stylesheet" href="~/css/galeri.css" asp-append-version="true" />
}

<div class="page-container">
    <div class="content-wrapper container">
        <header class="page-header">
            <div class="header-badge">GÖRSEL KOLEKSİYON</div>
            <h1 class="page-title">Galeri</h1>
            <p class="page-desc">Kokteyl sanatı, workshoplar ve premium etkinliklerin en iyi anları</p>
        </header>

        <section class="gallery-grid">
            <!-- Item 1: Tall -->
            <div class="gallery-item gallery-item--tall">
                <img src="~/images/gallery/gallery-1.jpg" alt="Kokteyl Sanatı" />
                <span class="category-badge">Kokteyl</span>
                <div class="item-overlay">
                    <div class="overlay-content">
                        <h3>İmza Kokteyller</h3>
                        <p>Sunum ve lezzetin buluştuğu anlar</p>
                        <i class="bi bi-zoom-in"></i>
                    </div>
                </div>
            </div>

            <!-- Item 2 -->
            <div class="gallery-item">
                <img src="~/images/gallery/gallery-2.jpg" alt="Workshop Hazırlığı" />
                <span class="category-badge">Workshop</span>
                <div class="item-overlay">
                    <div class="overlay-content">
                        <h3>Workshop Anları</h3>
                        <i class="bi bi-zoom-in"></i>
                    </div>
                </div>
            </div>

            <!-- Item 3 -->
            <div class="gallery-item">
                <img src="~/images/gallery/gallery-3.jpg" alt="Premium Servis" />
                <span class="category-badge">Servis</span>
                <div class="item-overlay">
                    <div class="overlay-content">
                        <h3>Premium Servis</h3>
                        <i class="bi bi-zoom-in"></i>
                    </div>
                </div>
            </div>

            <!-- Item 4: Tall -->
            <div class="gallery-item gallery-item--tall">
                <img src="~/images/gallery/gallery-4.jpg" alt="Neon Cocktails" />
                <span class="category-badge">Workshop</span>
                <div class="item-overlay">
                    <div class="overlay-content">
                        <h3>Workshop Sınıfı</h3>
                        <i class="bi bi-zoom-in"></i>
                    </div>
                </div>
            </div>

            <!-- Item 5 -->
            <div class="gallery-item">
                <img src="~/images/gallery/gallery-5.jpg" alt="Bar Kurulumu" />
                <span class="category-badge">Catering</span>
                <div class="item-overlay">
                    <div class="overlay-content">
                        <h3>Bar Kurulumu</h3>
                        <i class="bi bi-zoom-in"></i>
                    </div>
                </div>
            </div>

            <!-- Item 6: Wide -->
            <div class="gallery-item gallery-item--wide">
                <img src="~/images/gallery/gallery-6.jpg" alt="Eğitim Anları" />
                <span class="category-badge">Eğitim</span>
                <div class="item-overlay">
                    <div class="overlay-content">
                        <h3>Miksoloji Eğitimi</h3>
                        <i class="bi bi-zoom-in"></i>
                    </div>
                </div>
            </div>

            <!-- Item 7 -->
            <div class="gallery-item">
                <img src="~/images/gallery/gallery-7.jpg" alt="Artisan Malzemeler" />
                <span class="category-badge">Kokteyl</span>
                <div class="item-overlay">
                    <div class="overlay-content">
                        <h3>Artisan Malzemeler</h3>
                        <i class="bi bi-zoom-in"></i>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>
