@page
@model IndexModel
@{
    ViewData["Title"] = "Ana Sayfa";
    ViewData["Description"] = "Hakan Balta ile HB Liquid Arts Collective. Butik içecek danışmanlığı, miksoloji akademisi, catering hizmetleri.";
}

@section Styles {
    <link rel="stylesheet" href="~/css/index.css" asp-append-version="true" />
}

@* Hero Section *@
<section class="hero-section">
    <div class="container hero-wrapper">
        <div class="hero-content">
            <span class="badge-premium">MİKOLOJİ & DANIŞMANLIK</span>

            <h1 class="hero-title">
                HB Liquid Arts <br>
                <span class="text-gold">Collective</span>
            </h1>

            <p class="hero-description">
                Butik içecek danışmanlığı ve miksoloji akademisi. Sıradan deneyimleri olağanüstü sıvı sanatına dönüştürüyoruz.
            </p>

            <div class="hero-actions">
                <a href="#" class="btn-primary-gold">Fiyat Teklifi Al</a>
                <a href="#" class="btn-outline-gold">Portfolyoyu Görüntüle</a>
            </div>

            <div class="hero-stats">
                <div class="stat-item">
                    <span class="stat-number">15+</span>
                    <span class="stat-label">Yıl Deneyim</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">500+</span>
                    <span class="stat-label">Etkinlik</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">1K+</span>
                    <span class="stat-label">Öğrenci</span>
                </div>
            </div>
        </div>

        <div class="hero-image-area">
            <div class="hero-image-container">
                <img src="~/images/hakan-balta.jpg" alt="Hakan Balta" class="hero-profile-img">
            </div>
        </div>
    </div>
</section>

@* Event Section *@
<section class="events-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Yaklaşan Etkinlikler</h2>
            <p class="section-subtitle">Miksoloji deneyiminizi geliştirmek için özel workshop ve tadım etkinliklerimize katılın</p>
        </div>

        <div class="slider-wrapper">
            <button class="slider-nav-btn prev" aria-label="Geri">
                <i class="bi bi-chevron-left"></i>
            </button>

            <div class="events-slider">
                @* Kart 1: Kokteyl Masterclass *@
                <div class="event-card">
                    <div class="card-image-wrapper">
                        <img src="/img/event-masterclass.jpg" alt="Kokteyl Masterclass">
                        <span class="badge-category">Workshop</span>
                    </div>
                    <div class="card-content">
                        <span class="badge-capacity">8 Kişilik</span>
                        <h3 class="event-name">Kokteyl Masterclass</h3>
                        <p class="event-desc">Klasik kokteyllerin modern yorumlarını öğrenin. Hands-on deneyim ile 8 farklı imza kokteyli.</p>
                        <div class="event-details">
                            <div class="detail-item"><i class="bi bi-calendar3"></i><span>15 Mart 2026</span></div>
                            <div class="detail-item"><i class="bi bi-clock"></i><span>19:00 - 22:00</span></div>
                            <div class="detail-item"><i class="bi bi-geo-alt"></i><span>HB Studio, İstanbul</span></div>
                        </div>
                        <a href="#" class="btn-register">Kayıt Ol <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>

                @* Kart 2: Craft Spirit Tadımı *@
                <div class="event-card">
                    <div class="card-image-wrapper">
                        <img src="/img/event-tasting.jpg" alt="Craft Spirit Tadımı">
                        <span class="badge-category">Tadım</span>
                    </div>
                    <div class="card-content">
                        <span class="badge-capacity">12 Kişilik</span>
                        <h3 class="event-name">Craft Spirit Tadımı</h3>
                        <p class="event-desc">Dünya'nın farklı bölgelerinden özenle seçilmiş craft spirit'leri keşfedin.</p>
                        <div class="event-details">
                            <div class="detail-item"><i class="bi bi-calendar3"></i><span>22 Mart 2026</span></div>
                            <div class="detail-item"><i class="bi bi-clock"></i><span>18:00 - 21:00</span></div>
                            <div class="detail-item"><i class="bi bi-geo-alt"></i><span>HB Tasting Room</span></div>
                        </div>
                        <a href="#" class="btn-register">Kayıt Ol <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>

                @* Kart 3: İleri Seviye Miksoloji *@
                <div class="event-card">
                    <div class="card-image-wrapper">
                        <img src="/img/event-advanced.jpg" alt="İleri Seviye Miksoloji">
                        <span class="badge-category">Workshop</span>
                    </div>
                    <div class="card-content">
                        <span class="badge-capacity">6 Kişilik</span>
                        <h3 class="event-name">İleri Seviye Miksoloji</h3>
                        <p class="event-desc">Profesyoneller için ileri teknikler: moleküler miksoloji, infüzyon ve aging.</p>
                        <div class="event-details">
                            <div class="detail-item"><i class="bi bi-calendar3"></i><span>5 Nisan 2026</span></div>
                            <div class="detail-item"><i class="bi bi-clock"></i><span>14:00 - 18:00</span></div>
                            <div class="detail-item"><i class="bi bi-geo-alt"></i><span>HB Academy</span></div>
                        </div>
                        <a href="#" class="btn-register">Kayıt Ol <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>

                @* Kart 4: Craft Spirit Tadımı (Tekrar) *@
                <div class="event-card">
                    <div class="card-image-wrapper">
                        <img src="/img/event-tasting.jpg" alt="Craft Spirit Tadımı">
                        <span class="badge-category">Tadım</span>
                    </div>
                    <div class="card-content">
                        <span class="badge-capacity">12 Kişilik</span>
                        <h3 class="event-name">Craft Spirit Tadımı</h3>
                        <p class="event-desc">Dünya'nın farklı bölgelerinden özenle seçilmiş craft spirit'leri keşfedin.</p>
                        <div class="event-details">
                            <div class="detail-item"><i class="bi bi-calendar3"></i><span>22 Mart 2026</span></div>
                            <div class="detail-item"><i class="bi bi-clock"></i><span>18:00 - 21:00</span></div>
                            <div class="detail-item"><i class="bi bi-geo-alt"></i><span>HB Tasting Room</span></div>
                        </div>
                        <a href="#" class="btn-register">Kayıt Ol <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>

                @* Kart 5: Craft Spirit Tadımı (Tekrar) *@
                <div class="event-card">
                    <div class="card-image-wrapper">
                        <img src="/img/event-tasting.jpg" alt="Craft Spirit Tadımı">
                        <span class="badge-category">Tadım</span>
                    </div>
                    <div class="card-content">
                        <span class="badge-capacity">12 Kişilik</span>
                        <h3 class="event-name">Craft Spirit Tadımı</h3>
                        <p class="event-desc">Dünya'nın farklı bölgelerinden özenle seçilmiş craft spirit'leri keşfedin.</p>
                        <div class="event-details">
                            <div class="detail-item"><i class="bi bi-calendar3"></i><span>22 Mart 2026</span></div>
                            <div class="detail-item"><i class="bi bi-clock"></i><span>18:00 - 21:00</span></div>
                            <div class="detail-item"><i class="bi bi-geo-alt"></i><span>HB Tasting Room</span></div>
                        </div>
                        <a href="#" class="btn-register">Kayıt Ol <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>

                @* Kart 6: Kokteyl Masterclass (Tekrar) *@
                <div class="event-card">
                    <div class="card-image-wrapper">
                        <img src="/img/event-masterclass.jpg" alt="Kokteyl Masterclass">
                        <span class="badge-category">Workshop</span>
                    </div>
                    <div class="card-content">
                        <span class="badge-capacity">8 Kişilik</span>
                        <h3 class="event-name">Kokteyl Masterclass</h3>
                        <p class="event-desc">Klasik kokteyllerin modern yorumlarını öğrenin. Hands-on deneyim ile 8 farklı imza kokteyli.</p>
                        <div class="event-details">
                            <div class="detail-item"><i class="bi bi-calendar3"></i><span>15 Mart 2026</span></div>
                            <div class="detail-item"><i class="bi bi-clock"></i><span>19:00 - 22:00</span></div>
                            <div class="detail-item"><i class="bi bi-geo-alt"></i><span>HB Studio, İstanbul</span></div>
                        </div>
                        <a href="#" class="btn-register">Kayıt Ol <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            <button class="slider-nav-btn next" aria-label="İleri">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>
    </div>
</section>

@* Hizmetlerimiz Bölümü *@
<section id="services" class="services-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Hizmetlerimiz</h2>
            <p class="section-subtitle">İçecek deneyiminizi yükseltmek için kapsamlı çözümler</p>
        </div>

        <div class="services-grid">
            @* Kart 1: Danışmanlık *@
            <div class="service-card">
                <div class="service-image">
                    <img src="/img/service-consultancy.jpg" alt="Danışmanlık">
                </div>
                <div class="service-content">
                    <div class="service-icon-wrapper">
                        <i class="bi bi-briefcase"></i>
                    </div>
                    <h3 class="service-title">Danışmanlık</h3>
                    <p class="service-text">Oteller, restoranlar ve premium mekanlar için stratejik içecek programı geliştirme, menü küratörlüğü ve bar tasarım danışmanlığı.</p>
                    <a href="#" class="btn-detail">Detayları Görüntüle <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>

            @* Kart 2: Workshop *@
            <div class="service-card">
                <div class="service-image">
                    <img src="/img/service-workshop.jpg" alt="Workshop">
                </div>
                <div class="service-content">
                    <div class="service-icon-wrapper">
                        <i class="bi bi-mortarboard"></i>
                    </div>
                    <h3 class="service-title">Workshop</h3>
                    <p class="service-text">Craft sanatında ustalaşmak isteyen meraklılar ve profesyoneller için tasarlanmış sürükleyici miksoloji sınıfları ve içki eğitim programları.</p>
                    <a href="#" class="btn-detail">Detayları Görüntüle <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>

            @* Kart 3: Catering *@
            <div class="service-card">
                <div class="service-image">
                    <img src="/img/service-catering.jpg" alt="Catering">
                </div>
                <div class="service-content">
                    <div class="service-icon-wrapper">
                        <i class="bi bi-stars"></i>
                    </div>
                    <h3 class="service-title">Catering</h3>
                    <p class="service-text">Premium sunum ve hizmetle özel etkinlikler, kurumsal fonksiyonlar ve kutlamalar için özel kokteyl deneyimleri.</p>
                    <a href="#" class="btn-detail">Detayları Görüntüle <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</section>

@* Projelerimiz Bölümü *@
<section id="projects" class="projects-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Proje Galerisi</h2>
            <p class="section-subtitle">En iyi yaratımlarımız ve unutulmaz deneyimlerimizin vitrini</p>
        </div>

        <div class="projects-grid">

            @* SATIR 1 — Kart 1: Sol sütun — Tall *@
            <div class="project-card h-lg">
                <div class="project-image">
                    <img src="https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?auto=format&fit=crop&q=80&w=800" alt="Signature Cocktails">
                </div>
                <div class="project-overlay">
                    <div class="project-info">
                        <span class="project-category">Miksoloji Tasarımı</span>
                        <h3 class="project-title">Signature Cocktails</h3>
                        <a href="#" class="btn-project-detail">İncele <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            @* SATIR 1 — Kart 2: Orta sütun — Tall *@
            <div class="project-card h-lg">
                <div class="project-image">
                    <img src="https://images.unsplash.com/photo-1470337458703-46ad1756a187?auto=format&fit=crop&q=80&w=800" alt="Artisan Kokteyl Malzemeleri">
                </div>
                <div class="project-overlay">
                    <div class="project-info">
                        <span class="project-category">Danışmanlık</span>
                        <h3 class="project-title">Artisan Kokteyl Malzemeleri</h3>
                        <a href="#" class="btn-project-detail">İncele <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            @* SATIR 1 — Kart 3: Sağ sütun — Kısa (altta boşluk oluşur) *@
            <div class="project-card h-xs">
                <div class="project-image">
                    <img src="https://images.unsplash.com/photo-1551024709-8f23befc6f87?auto=format&fit=crop&q=80&w=800" alt="Akademi Programı">
                </div>
                <div class="project-overlay">
                    <div class="project-info">
                        <span class="project-category">Workshop</span>
                        <h3 class="project-title">Akademi Programı</h3>
                        <a href="#" class="btn-project-detail">İncele <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            @* SATIR 2 — Kart 4: Sol sütun — Extra Tall *@
            <div class="project-card h-xl">
                <div class="project-image">
                    <img src="https://images.unsplash.com/photo-1536935338788-846bb9981813?auto=format&fit=crop&q=80&w=800" alt="Premium Bar Tasarımı">
                </div>
                <div class="project-overlay">
                    <div class="project-info">
                        <span class="project-category">Bar Tasarımı</span>
                        <h3 class="project-title">Premium Bar Tasarımı</h3>
                        <a href="#" class="btn-project-detail">İncele <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            @* SATIR 2 — Kart 5: Orta sütun — Kısa *@
            <div class="project-card h-sm">
                <div class="project-image">
                    <img src="https://images.unsplash.com/photo-1560512823-829485b8bf24?auto=format&fit=crop&q=80&w=800" alt="Lüks Kokteyl Barı">
                </div>
                <div class="project-overlay">
                    <div class="project-info">
                        <span class="project-category">Premium Catering</span>
                        <h3 class="project-title">Lüks Kokteyl Barı</h3>
                        <a href="#" class="btn-project-detail">İncele <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            @* SATIR 2 — Kart 6: Sağ sütun — Tall *@
            <div class="project-card h-lg">
                <div class="project-image">
                    <img src="https://images.unsplash.com/photo-1510626176961-4b57d4fbad03?auto=format&fit=crop&q=80&w=800" alt="Etkinlik Catering Hizmeti">
                </div>
                <div class="project-overlay">
                    <div class="project-info">
                        <span class="project-category">Özel Menü</span>
                        <h3 class="project-title">Etkinlik Catering Hizmeti</h3>
                        <a href="#" class="btn-project-detail">İncele <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

@* İletişim Formu *@
<div id="contact">
    @await Html.PartialAsync("_ContactForm")
</div>

@section Scripts {
    <script src="~/js/anasayfa/index.js"></script>
}