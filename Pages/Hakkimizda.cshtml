@page
@model HakkimizdaModel
@{
    ViewData["Title"] = "Hakkımızda";
}

@section Styles {
    <link rel="stylesheet" href="~/css/hakkimizda.css" asp-append-version="true" />
}

<div class="page-container">
    <div class="content-wrapper container">
        <!-- 1. Bölüm: Kurucu Title -->
        <header class="page-header text-center">
            <h1 class="page-title">Kurucumuz</h1>
            <p class="page-desc">Sıvı sanat konusunda tutkulu bir vizyon sahibi</p>
        </header>

        <!-- 2. Bölüm: Kurucu Detay -->
        <section class="founder-section">
            <div class="founder-grid">
                <div class="founder-image">
                    <img src="~/images/about/founder.jpg" alt="Hakan Balta - Kurucu" />
                </div>
                <div class="founder-info">
                    <div class="info-card">
                        <h2 class="info-title">Hikaye</h2>
                        <div class="info-text">
                            <p>HB Liquid Arts Kolektifi'nin kurucusu olarak, miksoloji sanatına olan tutkunum 15 yılı aşkın bir süreye yayılıyor. Yolculuğum, dünyanın en prestijli barlarından bazılarında çalışarak ve uluslararası kokteyl yarışmalarında yarışarak başladı.</p>
                            <p>Yıllar içinde, craft kokteyllerin sadece içecekler değil, sanat eserleri olduğuna dair inancımı geliştirdim. Her karışım bir hikaye anlatır, her tat profili bir deneyim yaratır. Bu felsefe, HB Liquid Arts Kolektifi'nin temelini oluşturur.</p>
                            <p>Bugün, amacım bilgimi ve uzmanlığımı yeni nesil miksologlara aktarmak ve işletmelerin benzersiz, unutulmaz içecek deneyimleri yaratmasına yardımcı olmaktır.</p>
                            <p>Craft kokteyl kültürünün Türkiye'de büyümesine katkıda bulunmaktan ve daha fazla insanın bu sanatın güzelliğini keşfetmesine yardımcı olmaktan gurur duyuyorum.</p>
                        </div>
                    </div>
                    
                    <blockquote class="founder-motto">
                        <p>"Miksoloji bir bilimdir, bir sanattır ve bir tutku. Her bardak, yaratıcılığın ve özverinin bir kutlamasıdır."</p>
                    </blockquote>
                </div>
            </div>
        </section>

        <!-- 3. Bölüm: Başarılar -->
        <section class="achievements-section">
            <h2 class="section-title text-center">Başarılar</h2>
            <div class="achievements-grid">
                <div class="achievement-card">
                    <div class="icon-box">
                        <i class="bi bi-award"></i>
                    </div>
                    <h3 class="achievement-number">15+ Yıl Deneyim</h3>
                    <p class="achievement-label">Miksoloji ve içki endüstrisinde uzman</p>
                </div>

                <div class="achievement-card">
                    <div class="icon-box">
                        <i class="bi bi-people"></i>
                    </div>
                    <h3 class="achievement-number">500+ Etkinlik</h3>
                    <p class="achievement-label">Başarıyla tamamlanmış premium organizasyon</p>
                </div>

                <div class="achievement-card">
                    <div class="icon-box">
                        <i class="bi bi-book"></i>
                    </div>
                    <h3 class="achievement-number">1000+ Öğrenci</h3>
                    <p class="achievement-label">Eğitilen ve sertifikalandırılan profesyonel</p>
                </div>

                <div class="achievement-card">
                    <div class="icon-box">
                        <i class="bi bi-star"></i>
                    </div>
                    <h3 class="achievement-number">Uluslararası Ödüller</h3>
                    <p class="achievement-label">Sektör genelinde tanınma ve onur</p>
                </div>
            </div>
        </section>
    </div>
</div>
